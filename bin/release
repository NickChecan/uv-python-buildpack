#!/usr/bin/env bash
# Release script for Python buildpack with uv support

set -euo pipefail

BUILD_DIR="${1:?BUILD_DIR argument is required}"
cd "$BUILD_DIR"

# Prefer the Python interpreter staged by `bin/compile`, but fall back to a
# system interpreter so local development and unit tests can still run.
if [ -x ".python/bin/python3" ]; then
  PYTHON_BIN=".python/bin/python3"
elif [ -x ".python/bin/python" ]; then
  PYTHON_BIN=".python/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="python3"
elif command -v python >/dev/null 2>&1; then
  PYTHON_BIN="python"
else
  PYTHON_BIN="python"
fi

resolve_script_target() {
  # Parse pyproject.toml with Python so we can safely read TOML instead of
  # relying on brittle grep/awk parsing.
  "$PYTHON_BIN" -c '
import sys
try:
    import tomllib
except ModuleNotFoundError:
    import tomli as tomllib

with open("pyproject.toml", "rb") as f:
    data = tomllib.load(f)

project = data.get("project", {})
project_name = project.get("name", "")
scripts = project.get("scripts", {})

print(scripts.get(project_name) or scripts.get("start", ""))
'
}

build_python_entrypoint() {
  # Convert a console-script target like `server.main:start` into a command
  # that invokes the same callable directly with the resolved interpreter.
  local target="$1"
  local module_name="${target%%:*}"
  local function_name="${target##*:}"
  echo "${PYTHON_BIN} -c \"from ${module_name} import ${function_name}; ${function_name}()\""
}

DEFAULT_WEB_PROCESS=""

# Procfile wins. When it exists, Cloud Foundry will read it directly and the
# buildpack should not emit a generated default process type.
if [ -f "Procfile" ]; then
  exit 0
fi

# Without a Procfile, try to synthesize a Python command from pyproject.toml.
# We prefer a console script that matches `project.name`, then fall back to
# a generic `start` script if one exists.
if [ -f "pyproject.toml" ]; then
  SCRIPT_TARGET="$(resolve_script_target)"
  if [ -n "$SCRIPT_TARGET" ]; then
    DEFAULT_WEB_PROCESS="$(build_python_entrypoint "$SCRIPT_TARGET")"
  fi
fi

# If there are no console scripts, fall back to common single-file app layouts.
if [ -z "$DEFAULT_WEB_PROCESS" ] && [ -f "main.py" ]; then
  DEFAULT_WEB_PROCESS="${PYTHON_BIN} main.py"
fi

if [ -z "$DEFAULT_WEB_PROCESS" ] && [ -f "app.py" ]; then
  DEFAULT_WEB_PROCESS="${PYTHON_BIN} app.py"
fi

cat <<EOF
---
default_process_types:
  web: ${DEFAULT_WEB_PROCESS}
EOF
